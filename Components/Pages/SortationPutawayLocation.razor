@page "/sortation-putaway/location"
@inject SortationFlowState SortationFlow
@inject OpenBoxesApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Putaway Location Scan</PageTitle>

@if (_task is null)
{
    <div class="ob-empty-state"><h2>Putaway Details Not Found</h2></div>
}
else
{
    <h1>Scan Putaway Location Barcode</h1>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="ob-card">
        <div class="d-flex gap-2 flex-wrap">
            <span class="badge bg-light text-dark border">Product Code: @JsonNodeHelpers.Get(_task, "inventoryItem.product.productCode")</span>
            <span class="badge text-dark" style="background:#FCFFC1">@JsonNodeHelpers.Get(_task, "type")</span>
        </div>

        <h2 class="mt-3">@JsonNodeHelpers.Get(_task, "inventoryItem.product.name")</h2>
        <div class="mt-2 d-flex gap-2 flex-wrap">
            <span class="badge bg-light text-dark border">Putaway Container ID: @JsonNodeHelpers.Get(_task, "container.locationNumber")</span>
            <span class="badge bg-light text-dark border">Putaway Location: @JsonNodeHelpers.Get(_selectedDestination ?? _task, "destination.name")</span>
            <span class="badge bg-light text-dark border">Putaway Quantity: @JsonNodeHelpers.Get(_task, "quantity")</span>
        </div>
    </div>

    <div class="ob-card">
        <label class="form-label">Putaway Location Entry Field</label>
        <input class="form-control" @bind="_locationBarcode" />

        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="fw-semibold">Alternative Location?</span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="RequestAlternativeLocations">Request</button>
        </div>

        @if (_alternativeDestinations.Count > 0)
        {
            <div class="mt-2">
                <select class="form-select" @bind="_selectedAlternativeId">
                    @foreach (var d in _alternativeDestinations)
                    {
                        <option value="@JsonNodeHelpers.Get(d, "id", string.Empty)">@JsonNodeHelpers.Get(d, "name") (@JsonNodeHelpers.Get(d, "locationNumber"))</option>
                    }
                </select>
                <button class="btn btn-sm btn-ob-primary mt-2" @onclick="ApplyAlternative">Apply Selected Location</button>
            </div>
        }

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-ob-primary" @onclick="Confirm">Confirm</button>
            <button class="btn btn-outline-secondary" @onclick="Skip">Skip</button>
        </div>
    </div>
}

@code {
    private JsonObject? _task;
    private JsonObject? _selectedDestination;
    private string _locationBarcode = string.Empty;
    private string? _error;

    private List<JsonObject> _alternativeDestinations = [];
    private string _selectedAlternativeId = string.Empty;

    protected override void OnInitialized()
    {
        _task = SortationFlow.CurrentTask;
        _selectedDestination = _task;
    }

    private async Task RequestAlternativeLocations()
    {
        if (_task is null) return;

        var facilityId = JsonNodeHelpers.Get(_task, "facility.id", string.Empty);
        var taskId = JsonNodeHelpers.Get(_task, "id", string.Empty);

        try
        {
            var response = await ApiClient.GetAlternativeDestinationsAsync(facilityId, taskId);
            _alternativeDestinations = JsonNodeHelpers.ToObjectList(response?["data"] ?? response).ToList();
            _selectedAlternativeId = _alternativeDestinations.Count > 0 ? JsonNodeHelpers.Get(_alternativeDestinations[0], "id", string.Empty) : string.Empty;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void ApplyAlternative()
    {
        var alt = _alternativeDestinations.FirstOrDefault(x => JsonNodeHelpers.Get(x, "id", string.Empty) == _selectedAlternativeId);
        if (alt is null || _task is null) return;

        _task["destination"] = alt.DeepClone();
        _selectedDestination = _task;
    }

    private void Confirm()
    {
        if (_task is null)
        {
            return;
        }

        var expectedLocation = JsonNodeHelpers.Get(_task, "destination.locationNumber", string.Empty);
        if (!string.Equals(_locationBarcode, expectedLocation, StringComparison.OrdinalIgnoreCase))
        {
            _error = $"Scanned barcode {_locationBarcode} does not match expected location {expectedLocation}.";
            _locationBarcode = string.Empty;
            return;
        }

        Navigation.NavigateTo("sortation-putaway/product");
    }

    private void Skip()
    {
        var next = SortationFlow.CurrentTaskIndex + 1;
        if (next < SortationFlow.TaskList.Count)
        {
            SortationFlow.CurrentTaskIndex = next;
            Navigation.NavigateTo("sortation-putaway/location");
        }
        else
        {
            Navigation.NavigateTo(SortationFlow.IsDirectPutaway ? "sortation" : "sortation-putaway");
        }
    }
}
