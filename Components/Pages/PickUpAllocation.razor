@page "/pickup-allocation"
@inject SessionManager SessionManager
@inject OpenBoxesApiClient ApiClient
@inject AppState AppState
@inject NavigationManager Navigation

<PageTitle>Pick-Up Allocation</PageTitle>

<h1>Pick-Up Allocation</h1>

@if (!string.IsNullOrWhiteSpace(_error)) { <div class="alert alert-danger">@_error</div> }
@if (_loading) { <p>Loading outbound orders...</p> }
else
{
    <table class="table table-striped">
        <thead><tr><th>Identifier</th><th>Status</th><th>Origin</th><th>Date</th></tr></thead>
        <tbody>
        @foreach (var item in _items)
        {
            <tr>
                <td>@JsonNodeHelpers.Get(item, "identifier")</td>
                <td>@JsonNodeHelpers.Get(item, "status")</td>
                <td>@JsonNodeHelpers.Get(item, "origin.name")</td>
                <td>@JsonNodeHelpers.Get(item, "dateCreated")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<JsonObject> _items = [];

    protected override async Task OnInitializedAsync()
    {
        var session = await SessionManager.EnsureSessionAsync();
        if (session?.User is null) { Navigation.NavigateTo("/login", true); return; }

        var locationId = AppState.CurrentSession?.Location?.Id;
        if (string.IsNullOrWhiteSpace(locationId)) { _error = "No location selected."; _loading = false; return; }

        try { _items = JsonNodeHelpers.ToObjectList(await ApiClient.GetPickupAllocationOrdersAsync(locationId)); }
        catch (Exception ex) { _error = ex.Message; }
        _loading = false;
    }
}
