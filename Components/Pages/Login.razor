@page "/login"
@inject SessionManager SessionManager
@inject AppState AppState
@inject NavigationManager Navigation
@inject UiSettingsService UiSettings
@inject OpenBoxesApiClient ApiClient

<PageTitle>Login</PageTitle>

<div class="ob-login-screen">
    <div class="ob-login-logo-wrap">
        <img src="images/logo.png" alt="OpenBoxes logo" class="ob-login-logo" />
    </div>

    <div class="alert alert-secondary" role="status">
        API: <strong>@ApiClient.BaseUrl</strong>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }
    @if (!string.IsNullOrWhiteSpace(_info))
    {
        <div class="alert alert-info" role="status">@_info</div>
    }

    <EditForm Model="_form" OnValidSubmit="OnSubmit" class="ob-login-form">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <InputText id="username" class="form-control" @bind-Value="_form.Username" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <InputText id="password" class="form-control" type="password" @bind-Value="_form.Password" />
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-ob-primary" disabled="@_loading">
                @(_loading ? "Logging in..." : "Login")
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="TestConnection" disabled="@_testing">
                @(_testing ? "Testing..." : "Test API Connection")
            </button>
            <a class="btn btn-link" href="settings">Settings</a>
        </div>
    </EditForm>
</div>

@code {
    private LoginForm _form = new();
    private bool _loading;
    private bool _testing;
    private string? _error;
    private string? _info;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await UiSettings.EnsureLoadedAsync(ApiClient.BaseUrl);
        var session = await SessionManager.EnsureSessionAsync();
        if (session?.User is not null)
        {
            Navigation.NavigateTo("dashboard", true);
        }
        else if (!string.IsNullOrWhiteSpace(AppState.LastError))
        {
            _error = AppState.LastError;
        }

        StateHasChanged();
    }

    private async Task OnSubmit()
    {
        _loading = true;
        _error = null;
        _info = null;

        var success = await SessionManager.LoginAsync(_form.Username, _form.Password);
        if (success)
        {
            Navigation.NavigateTo("dashboard", true);
        }
        else
        {
            _error = AppState.LastError ?? "Unable to authenticate user with the credentials provided.";
        }

        _loading = false;
    }

    private async Task TestConnection()
    {
        _testing = true;
        _error = null;
        _info = null;

        try
        {
            var reachable = await ApiClient.CanReachServerAsync();
            if (!reachable)
            {
                _error = $"API unreachable: {ApiClient.BaseUrl}";
                return;
            }

            _info = "API reachable. You can proceed with login.";
        }
        catch (Exception ex)
        {
            _error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _testing = false;
        }
    }

    private sealed class LoginForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username not provided")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password not provided")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Password is less than 6 characters")]
        public string Password { get; set; } = string.Empty;
    }
}
