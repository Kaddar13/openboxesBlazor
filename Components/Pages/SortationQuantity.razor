@page "/sortation/quantity/{TaskId}"
@inject SortationFlowState SortationFlow
@inject OpenBoxesApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Sortation Quantity</PageTitle>

@if (_task is null || _product is null)
{
    <div class="ob-empty-state">
        <h2>Product Not Found</h2>
        <p>The product or task is not available.</p>
        <a class="btn btn-outline-secondary" href="sortation">Back</a>
    </div>
}
else
{
    <h1>Enter Quantity for Sortation</h1>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="ob-card">
        <div class="d-flex gap-2 flex-wrap">
            <span class="badge bg-light text-dark border">Product Code: @JsonNodeHelpers.Get(_product, "productCode")</span>
            <span class="badge text-dark" style="background:#FCFFC1">@JsonNodeHelpers.Get(_task, "type")</span>
        </div>

        <h2 class="mt-3">@JsonNodeHelpers.Get(_product, "name")</h2>

        <div class="mt-2 d-flex gap-2 flex-wrap">
            <span class="badge bg-light text-dark border">Putaway Zone: @JsonNodeHelpers.Get(_task, "destination.zoneName")</span>
            <span class="badge bg-light text-dark border">Quantity Required: @JsonNodeHelpers.Get(_task, "quantity")</span>
            <span class="badge bg-light text-dark border">Assignee: @JsonNodeHelpers.Get(_task, "assignee.firstName") @JsonNodeHelpers.Get(_task, "assignee.lastName")</span>
            <span class="badge bg-light text-dark border">Container: @JsonNodeHelpers.Get(_task, "container.locationNumber")</span>
            <span class="badge bg-light text-dark border">Final Storage Location: @JsonNodeHelpers.Get(_task, "destination.name")</span>
        </div>

        <hr />

        <div class="form-check form-switch">
            <input id="directPutaway" class="form-check-input" type="checkbox" @bind="SortationFlow.IsDirectPutaway" />
            <label class="form-check-label" for="directPutaway">Direct Putaway Required</label>
        </div>
    </div>

    <div class="ob-card">
        <label class="form-label">Sortation Quantity</label>
        <input type="number" min="0" class="form-control" @bind="_quantitySorted" />

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-ob-primary" @onclick="Confirm">Confirm</button>
            <a class="btn btn-outline-secondary" href="sortation">Cancel</a>
        </div>
    </div>
}

@code {
    [Parameter]
    public string TaskId { get; set; } = string.Empty;

    private JsonObject? _task;
    private JsonObject? _product;
    private string? _error;
    private int? _quantitySorted;

    private static readonly HashSet<string> StartedTaskIds = [];

    protected override async Task OnInitializedAsync()
    {
        _task = SortationFlow.TaskList.FirstOrDefault(t => JsonNodeHelpers.Get(t, "id", string.Empty) == TaskId);
        _product = SortationFlow.Product;

        if (_task is not null && JsonNodeHelpers.Get(_task, "status", string.Empty).Equals("PENDING", StringComparison.OrdinalIgnoreCase))
        {
            var taskId = JsonNodeHelpers.Get(_task, "id", string.Empty);
            if (!StartedTaskIds.Contains(taskId))
            {
                var facilityId = JsonNodeHelpers.Get(_task, "facility.id", string.Empty);
                var response = await ApiClient.PatchPutawayTaskAsync(facilityId, taskId, new { action = "start" });
                if (response is not null)
                {
                    StartedTaskIds.Add(taskId);
                }
            }
        }
    }

    private void Confirm()
    {
        if (_task is null)
        {
            return;
        }

        var totalQuantity = int.TryParse(JsonNodeHelpers.Get(_task, "quantity", "0"), out var qty) ? qty : 0;

        if (!_quantitySorted.HasValue || _quantitySorted <= 0)
        {
            _error = "Please enter a valid quantity greater than zero.";
            return;
        }

        if (_quantitySorted > totalQuantity)
        {
            _error = "Quantity to sort can not be greater than quantity in total.";
            return;
        }

        if (SortationFlow.IsDirectPutaway)
        {
            SortationFlow.TaskList = [_task];
            SortationFlow.CurrentTaskIndex = 0;
            Navigation.NavigateTo("sortation-putaway/location");
            return;
        }

        Navigation.NavigateTo($"/sortation/container/{TaskId}?quantity={_quantitySorted}");
    }
}
