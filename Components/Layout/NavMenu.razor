@implements IDisposable
@inject AppState AppState
@inject SessionManager SessionManager
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="dashboard">OpenBoxes</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <div class="session-box px-3 py-3">
        <div class="avatar">U</div>
        <div>
            <div class="session-item session-main">@AppState.CurrentSession?.User?.Username</div>
            <div class="session-item">@AppState.CurrentSession?.Location?.Name</div>
        </div>
    </div>

    <nav class="nav flex-column">
        <div class="nav-item px-3"><NavLink class="nav-link" href="locations">Choose Location</NavLink></div>
        <div class="nav-item px-3"><NavLink class="nav-link" href="dashboard">Dashboard</NavLink></div>
    </nav>

    <div class="menu-bottom px-3">
        <a class="btn btn-outline-light w-100 mb-2" href="settings">Settings</a>
        <button class="btn btn-light w-100" @onclick="OnLogout">Logout</button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AppState.StateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private async Task OnLogout()
    {
        await SessionManager.LogoutAsync();
        Navigation.NavigateTo("login");
    }

    public void Dispose()
    {
        AppState.StateChanged -= OnStateChanged;
    }
}
